<IfModule mod_rewrite.c>
    RewriteEngine On

    # SEO-friendly public video detail URL:
    # video-25-judul-video.html -> video-detail.php?id=25&slug=judul-video
    RewriteRule ^video-([1-9][0-9]*)-([a-z0-9-]+)\.html$ video-detail.php?id=$1&slug=$2 [L,QSA,NC]
</IfModule>

# Page-view collector must never be served from cache.
<IfModule mod_headers.c>
    <Files "analytics-collect.php">
        Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header always set Pragma "no-cache"
    </Files>
</IfModule>
