Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Jangan memproses file dan folder yang benar-benar tersedia
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Detail produk SEO-friendly
    # /produk-mikrotik-crs518-16xs-2xq-rm
    # diarahkan ke:
    # /produk-detail.php?slug=mikrotik-crs518-16xs-2xq-rm
    RewriteRule ^produk-([a-z0-9][a-z0-9-]*)/?$ produk-detail.php?slug=$1 [L,QSA,NC]

    # Detail video SEO-friendly
    RewriteRule ^video-([1-9][0-9]*)-([a-z0-9-]+)\.html$ video-detail.php?id=$1&slug=$2 [L,QSA,NC]
</IfModule>

# Lindungi file sensitif
<FilesMatch "^(\.env|composer\.(json|lock)|.*\.(sql|log|ini|bak|dist))$">
    Require all denied
</FilesMatch>

# Page-view collector must never be served from cache.
<IfModule mod_headers.c>
    <Files "analytics-collect.php">
        Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header always set Pragma "no-cache"
    </Files>
</IfModule>
